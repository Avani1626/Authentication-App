{
  "name": "calc-app-backend",
  "version": "1.0.0",
  "description": "Node.js + TypeScript backend for the calculator app with Firebase auth",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
